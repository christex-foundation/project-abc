// Future of Work (FOW) — Prisma schema
// Source of truth: §3 of the Technical Implementation Plan.
//
// The full data model lands in the initial migration so subsequent phases
// add features, not tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  COMPANY
  FREELANCER
  ADMIN
}

enum BountyStatus {
  DRAFT
  FUNDED
  ACTIVE
  JUDGING
  COMPLETED
  CANCELLED
}

enum BountyType {
  BOUNTY
  PROJECT
}

// Sierra Leone administrative geography. Used for provincial targeting of
// bounties and for freelancer location. Province targeting is enforced at
// submission time; District is captured on the freelancer for display and
// finer future matching.
enum Province {
  EASTERN
  NORTHERN
  NORTH_WEST
  SOUTHERN
  WESTERN_AREA
}

enum District {
  // Eastern
  KAILAHUN
  KENEMA
  KONO
  // Northern
  BOMBALI
  FALABA
  KOINADUGU
  TONKOLILI
  // North West
  KAMBIA
  KARENE
  PORT_LOKO
  // Southern
  BO
  BONTHE
  MOYAMBA
  PUJEHUN
  // Western Area
  WESTERN_AREA_URBAN
  WESTERN_AREA_RURAL
}

enum CompensationType {
  FIXED
  RANGE
  VARIABLE
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionLabel {
  UNREVIEWED
  REVIEWED
  SHORTLISTED
  SPAM
  LOW_QUALITY
  MID_QUALITY
  HIGH_QUALITY
}

enum PaymentType {
  ESCROW_DEPOSIT
  PRIZE_PAYOUT
  MILESTONE_PAYOUT // project milestone tranche payout (escrow → contractor)
  REFUND
}

enum PaymentMethod {
  CHECKOUT
  INTERNAL_TRANSFER
  MOMO_PAYOUT
}

enum WithdrawalStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum CreditTxnReason {
  MONTHLY_RESET
  SUBMISSION_SPEND
  PROPOSAL_SPEND
  WIN_BONUS
  SPAM_PENALTY
  ADMIN_GRANT
  ADMIN_REVOKE
  REFERRAL_FIRST_SUBMISSION
  REFERRAL_WIN_BONUS
  REFERRAL_REVERSAL
}

// =============================================================================
// Project domain enums
//   Projects are ongoing one-company-one-contractor engagements (distinct from
//   the competitive Bounty flow). Contractors apply with a proposal + their own
//   milestone breakdown; the company awards one; work proceeds milestone by
//   milestone with per-milestone updates, comments, and tranche payouts.
// =============================================================================

enum ProjectStatus {
  DRAFT // company drafting
  OPEN // published, accepting proposals
  AWARDED // proposal chosen, awaiting escrow funding
  ACTIVE // escrow funded, milestone loop running
  COMPLETED // all milestones approved & paid
  CANCELLED
}

enum MilestoneStatus {
  PENDING // locked behind a prior milestone
  IN_PROGRESS // active, contractor working
  IN_REVIEW // contractor posted an update = approval request
  CHANGES_REQUESTED // company asked for changes; contractor resubmits
  APPROVED // tranche paid, terminal
}

enum ProposalStatus {
  SUBMITTED
  WITHDRAWN
  AWARDED
  REJECTED
}

// =============================================================================
// Better Auth tables
//   - `user` is extended via Better Auth's `additionalFields` (role, phoneNumber, isActive).
//   - Adapter-managed tables: account, session, verification.
// =============================================================================

model User {
  id            String   @id
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  // Custom fields (additionalFields)
  role          UserRole @default(FREELANCER)
  phoneNumber   String?
  isActive      Boolean  @default(true)
  // Referral system — short shareable code (nullable until lazily generated)
  referralCode  String?  @unique
  // Public profile handle for the shareable /u/[handle] page. Nullable until
  // generated from the user's display/company name (lazily or at profile creation).
  handle        String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts          Account[]
  sessions          Session[]
  companyProfile    CompanyProfile?
  freelancerProfile FreelancerProfile?

  invitesCreated    CompanyInvite[]         @relation("InviteCreatedBy")
  invitesAcceptedBy CompanyInvite[]         @relation("InviteAcceptedBy")
  settingsTouched   Setting[]
  notifications     Notification[]
  notificationPrefs NotificationPreference?
  pushSubscriptions PushSubscription[]
  raisedDisputes    Dispute[]
  withdrawals       AccountWithdrawal[]
  creditTxnsAsAdmin CreditTransaction[]     @relation("CreditTxnAdmin")
  milestoneUpdates  MilestoneUpdate[]
  milestoneComments MilestoneComment[]
  reviewsAuthored   Review[]                @relation("ReviewsAuthored")
  reviewsReceived   Review[]                @relation("ReviewsReceived")

  @@map("user")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// =============================================================================
// Profiles
// =============================================================================

model CompanyProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  companyName              String
  description              String?
  website                  String?
  logo                     String?
  industry                 String?
  country                  String    @default("SL")
  verified                 Boolean   @default(false)
  monimeFinancialAccountId String? // Monime financial account UUID
  monimeUvan               String? // UVAN identifier
  // Verified withdrawal destination (KYC'd at setup; reused for every withdrawal)
  withdrawalPhone          String?
  withdrawalHolderName     String?
  withdrawalProviderName   String?
  withdrawalVerifiedAt     DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bounties Bounty[]
  projects Project[]
}

model FreelancerProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  displayName              String
  headline                 String?
  bio                      String?
  portfolio                String?
  experienceLevel          String?
  whatsappNumber           String?
  // Location (Sierra Leone). `district` always belongs to `province`; enforced
  // in the validator. Both nullable until the freelancer fills them in.
  province                 Province?
  district                 District?
  bankDetails              Json?
  aiEmbedding              Float[]
  monimeFinancialAccountId String? // Monime financial account UUID
  monimeUvan               String? // UVAN identifier
  // Verified withdrawal destination (KYC'd at setup; reused for every withdrawal)
  withdrawalPhone          String?
  withdrawalHolderName     String?
  withdrawalProviderName   String?
  withdrawalVerifiedAt     DateTime?
  creditsBalance           Int       @default(0)
  creditsPeriodKey         String? // "YYYY-MM" of the cached balance; null = never initialized
  // Referral — set once at signup when the new freelancer redeemed a code; immutable thereafter.
  referrerProfileId        String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills             FreelancerSkill[]
  submissions        Submission[]
  proofOfWorks       ProofOfWork[]
  creditTransactions CreditTransaction[]

  referrer            FreelancerProfile?  @relation("FreelancerReferrals", fields: [referrerProfileId], references: [id], onDelete: SetNull)
  referredFreelancers FreelancerProfile[] @relation("FreelancerReferrals")
  referralCreditTxns  CreditTransaction[] @relation("CreditTxnReferred")

  projectProposals   ProjectProposal[]
  contractedProjects Project[]         @relation("ProjectContractor")

  @@index([referrerProfileId])
}

// =============================================================================
// Skills taxonomy
// =============================================================================

model SkillCategory {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  skills Skill[]
}

model Skill {
  id            String  @id @default(cuid())
  name          String  @unique
  slug          String  @unique
  categoryId    String
  parentSkillId String? // null = top-level skill; non-null = sub-skill of another Skill

  category          SkillCategory      @relation(fields: [categoryId], references: [id])
  parent            Skill?             @relation("SkillHierarchy", fields: [parentSkillId], references: [id])
  children          Skill[]            @relation("SkillHierarchy")
  freelancerSkills  FreelancerSkill[]
  bountySkills      BountySkill[]
  projectSkills     ProjectSkill[]
  proofOfWorkSkills ProofOfWorkSkill[]

  @@index([categoryId])
  @@index([slug])
  @@index([parentSkillId])
}

model FreelancerSkill {
  id                  String @id @default(cuid())
  freelancerProfileId String
  skillId             String
  proficiencyLevel    Int // 1-5
  yearsExperience     Int?

  freelancer FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  skill      Skill             @relation(fields: [skillId], references: [id])

  @@unique([freelancerProfileId, skillId])
  @@index([freelancerProfileId])
  @@index([skillId])
}

// =============================================================================
// Proof of Work (freelancer portfolio items)
// =============================================================================

model ProofOfWork {
  id                  String   @id @default(cuid())
  freelancerProfileId String
  title               String
  description         String // length capped in validator
  link                String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  freelancer FreelancerProfile  @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  skills     ProofOfWorkSkill[]

  @@index([freelancerProfileId])
}

model ProofOfWorkSkill {
  id            String @id @default(cuid())
  proofOfWorkId String
  skillId       String

  proofOfWork ProofOfWork @relation(fields: [proofOfWorkId], references: [id], onDelete: Cascade)
  skill       Skill       @relation(fields: [skillId], references: [id])

  @@unique([proofOfWorkId, skillId])
  @@index([proofOfWorkId])
  @@index([skillId])
}

// =============================================================================
// Bounties
// =============================================================================

model Bounty {
  // Identity
  id                  String  @id @default(cuid())
  companyProfileId    String?
  // Captured when the owning company deletes their account so the bounty can be
  // attributed in the UI even after the FK is set to NULL (GDPR account deletion).
  companyNameSnapshot String?
  title               String
  slug                String  @unique
  description         String // sanitised HTML
  requirements        String? // sanitised HTML
  deliverables        String? // sanitised HTML

  // Type & status
  type   BountyType   @default(BOUNTY)
  status BountyStatus @default(DRAFT)

  // Compensation
  compensationType CompensationType @default(FIXED)
  currency         String           @default("SLE")
  totalPrizePool   Int // minor units
  rewardAmount     Int?
  minRewardAsk     Int?
  maxRewardAsk     Int?
  rewards          Json?

  // Winners
  numberOfWinners    Int       @default(1)
  maxBonusSpots      Int       @default(0)
  isWinnersAnnounced Boolean   @default(false)
  winnersAnnouncedAt DateTime?

  // Eligibility
  eligibility Json?

  // Access control
  //   - targetProvinces: empty = open nationwide; otherwise only freelancers
  //     whose profile province is in this list may submit (enforced server-side).
  //   - targetDistricts: empty = no district narrowing; otherwise districts refine
  //     the provincial lock — only freelancers in one of these districts may submit
  //     (the province check becomes implied). Every district must belong to a
  //     targeted province.
  //   - accessPinHash: null = open; otherwise a salted scrypt hash of the PIN
  //     that gates viewing the bounty's details and submitting to it.
  targetProvinces Province[] @default([])
  targetDistricts District[] @default([])
  accessPinHash   String?

  // Timeline
  timeToComplete     String?
  submissionDeadline DateTime
  judgingDeadline    DateTime?
  publishedAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?

  // Monime escrow
  escrowFinancialAccountId String?
  escrowFundedAmount       Int     @default(0)
  checkoutSessionId        String?
  checkoutSessionUrl       String?

  // AI
  aiEmbedding Float[]

  // Credit system
  creditsExempt Boolean @default(false)

  // Meta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company            CompanyProfile?     @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  prizeTiers         PrizeTier[]
  skills             BountySkill[]
  submissions        Submission[]
  payments           Payment[]
  disputes           Dispute[]
  creditTransactions CreditTransaction[]

  @@index([companyProfileId])
  @@index([status])
  @@index([slug])
}

model PrizeTier {
  id       String  @id @default(cuid())
  bountyId String
  position Int // 1=first place, 99=bonus
  amount   Int // minor units
  label    String?

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)

  @@unique([bountyId, position])
  @@index([bountyId])
}

model BountySkill {
  id         String  @id @default(cuid())
  bountyId   String
  skillId    String
  isRequired Boolean @default(false)

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id])

  @@unique([bountyId, skillId])
  @@index([bountyId])
  @@index([skillId])
}

// =============================================================================
// Submissions
// =============================================================================

model Submission {
  id                     String  @id @default(cuid())
  bountyId               String
  freelancerProfileId    String?
  // Captured when the freelancer deletes their account so the sponsor can still
  // attribute the submission after the FK is set to NULL (GDPR account deletion).
  freelancerNameSnapshot String?

  // Content
  link      String
  tweet     String?
  otherInfo String? // sanitised HTML

  // Status
  status   SubmissionStatus @default(PENDING)
  label    SubmissionLabel  @default(UNREVIEWED)
  isActive Boolean          @default(true)

  // Eligibility
  eligibilityAnswers Json?

  // Compensation
  ask Int? // minor units (RANGE/VARIABLE bounties)

  // Winner
  isWinner       Boolean @default(false)
  winnerPosition Int?

  // Judging
  score    Int?
  feedback String? // sanitised HTML, sponsor → freelancer
  notes    String? // sponsor-private, never returned to freelancer

  // Payment
  prizeAmount    Int?
  isPaid         Boolean @default(false)
  paymentDetails Json?

  // Meta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bounty             Bounty              @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  freelancer         FreelancerProfile?  @relation(fields: [freelancerProfileId], references: [id], onDelete: SetNull)
  payments           Payment[]
  creditTransactions CreditTransaction[]

  @@unique([bountyId, freelancerProfileId])
  @@index([bountyId])
  @@index([freelancerProfileId])
  @@index([status])
  @@index([label])
}

// =============================================================================
// Projects (ongoing one-company-one-contractor engagements)
//   A separate domain from Bounty. Lifecycle:
//     DRAFT → OPEN (proposals) → AWARDED (escrow funded) → ACTIVE (milestone
//     loop) → COMPLETED. Escrow is funded AFTER award because the amount isn't
//     known until a proposal wins.
// =============================================================================

model Project {
  // Identity
  id                  String  @id @default(cuid())
  companyProfileId    String?
  // Captured when the owning company deletes their account (GDPR).
  companyNameSnapshot String?
  title               String
  slug                String  @unique
  description         String // sanitised HTML
  requirements        String? // sanitised HTML
  deliverables        String? // sanitised HTML — overall scope

  status   ProjectStatus @default(DRAFT)
  currency String        @default("SLE")

  // Access control (mirrors Bounty)
  //   - targetProvinces: empty = open nationwide; otherwise only freelancers
  //     whose profile province is in this list may submit a proposal.
  //   - targetDistricts: empty = no district narrowing; otherwise districts refine
  //     the provincial lock — only freelancers in one of these districts may apply
  //     (the province check becomes implied). Every district must belong to a
  //     targeted province.
  //   - accessPinHash: null = open; otherwise a salted scrypt hash of the PIN
  //     that gates viewing the project's brief and applying to it.
  targetProvinces Province[] @default([])
  targetDistricts District[] @default([])
  accessPinHash   String?

  // Budget ceiling shown publicly; a winning proposal's total must be <= this.
  budgetCap Int // minor units

  // Award / contractor (denormalised so workspace auth + payouts skip a 3-hop join)
  awardedProposalId      String? @unique
  contractorProfileId    String?
  contractorNameSnapshot String? // GDPR snapshot of the awarded contractor

  // Monime escrow (funded after award; mirrors Bounty escrow fields)
  escrowFinancialAccountId String?
  escrowFundedAmount       Int     @default(0)
  checkoutSessionId        String?
  checkoutSessionUrl       String?

  // AI matching
  aiEmbedding Float[]

  // Credit system
  creditsExempt Boolean @default(false)

  // Timeline
  timeToComplete String?
  publishedAt    DateTime?
  awardedAt      DateTime?
  activatedAt    DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?

  // Meta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company    CompanyProfile?    @relation(fields: [companyProfileId], references: [id], onDelete: SetNull)
  contractor FreelancerProfile? @relation("ProjectContractor", fields: [contractorProfileId], references: [id], onDelete: SetNull)

  skills     ProjectSkill[]
  proposals  ProjectProposal[]
  milestones Milestone[]
  payments   Payment[]
  disputes   Dispute[]
  reviews    Review[]
  // awardedProposal is resolved by id in the repo (no declared relation) to
  // avoid a relation cycle with `proposals`.

  @@index([companyProfileId])
  @@index([contractorProfileId])
  @@index([status])
  @@index([slug])
}

model ProjectSkill {
  id         String  @id @default(cuid())
  projectId  String
  skillId    String
  isRequired Boolean @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id])

  @@unique([projectId, skillId])
  @@index([projectId])
  @@index([skillId])
}

model ProjectProposal {
  id                     String         @id @default(cuid())
  projectId              String
  freelancerProfileId    String?
  freelancerNameSnapshot String? // GDPR
  coverLetter            String // sanitised HTML
  proposedTimeline       String? // free text, e.g. "6 weeks"
  status                 ProposalStatus @default(SUBMITTED)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer         FreelancerProfile?  @relation(fields: [freelancerProfileId], references: [id], onDelete: SetNull)
  creditTransactions CreditTransaction[]

  @@unique([projectId, freelancerProfileId]) // one proposal per freelancer per project
  @@index([projectId])
  @@index([freelancerProfileId])
  @@index([status])
}

model Milestone {
  id            String          @id @default(cuid())
  projectId     String
  position      Int
  title         String
  description   String? // sanitised HTML
  amount        Int // minor units; locked at funding
  dueInDays     Int?
  status        MilestoneStatus @default(PENDING)
  // Count of company-requested change rounds on this milestone (display only).
  revisionCount Int             @default(0)
  approvedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updates  MilestoneUpdate[]
  comments MilestoneComment[]
  payments Payment[]

  @@unique([projectId, position])
  @@index([projectId])
  @@index([status])
}

model MilestoneUpdate {
  id                 String   @id @default(cuid())
  milestoneId        String
  // Author is always the contractor; posting an update is the approval request.
  authorUserId       String?
  authorNameSnapshot String? // GDPR
  note               String // sanitised HTML
  deliverables       Json // [{ label, url }] — links only (validated in Zod)
  createdAt          DateTime @default(now())

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  author    User?     @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([milestoneId])
}

model MilestoneComment {
  id                 String   @id @default(cuid())
  milestoneId        String
  authorUserId       String? // either party (company owner or contractor)
  authorRole         UserRole // snapshot of who spoke; survives FK nulling
  authorNameSnapshot String? // GDPR
  body               String // sanitised HTML
  createdAt          DateTime @default(now())

  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  author    User?     @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([milestoneId])
}

// =============================================================================
// Payments
// =============================================================================

model Payment {
  id           String        @id @default(cuid())
  // Polymorphic owner: exactly one of bountyId / projectId is set (enforced by a
  // CHECK constraint appended as raw SQL in the migration). submissionId is set
  // for bounty prize payouts; milestoneId for project milestone tranche payouts.
  bountyId     String?
  submissionId String?
  projectId    String?
  milestoneId  String?
  type         PaymentType
  status       PaymentStatus @default(PENDING)
  currency     String        @default("SLE")
  amount       Int
  feeAmount    Int           @default(0)
  fromEntity   String?
  toEntity     String?

  method            PaymentMethod @default(CHECKOUT)
  checkoutSessionId String?
  monimePaymentId   String?
  monimePayoutId    String?
  monimeTransferId  String? // populated for INTERNAL_TRANSFER payments

  failureCode    String?
  failureMessage String?
  retryCount     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bounty     Bounty?     @relation(fields: [bountyId], references: [id])
  submission Submission? @relation(fields: [submissionId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])
  milestone  Milestone?  @relation(fields: [milestoneId], references: [id])

  @@index([bountyId])
  @@index([submissionId])
  @@index([projectId])
  @@index([milestoneId])
  @@index([status])
  @@index([monimePaymentId])
  @@index([monimePayoutId])
}

// =============================================================================
// Account withdrawals (user pulls from their financial account to mobile money)
// Stored separately from Payment because they are not tied to a specific bounty.
// =============================================================================

model AccountWithdrawal {
  id             String           @id @default(cuid())
  userId         String
  role           UserRole // COMPANY | FREELANCER — whose account was withdrawn from
  fromAccountId  String // Monime financial account ID
  toPhoneNumber  String // Destination MoMo number (KYC-verified)
  holderName     String // Confirmed via Monime provider KYC
  providerName   String // e.g. "Orange Money"
  amount         Int // minor units
  currency       String           @default("SLE")
  monimePayoutId String           @unique
  status         WithdrawalStatus @default(PROCESSING)
  failureCode    String?
  failureMessage String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([monimePayoutId])
  @@index([status])
}

// =============================================================================
// Disputes
// =============================================================================

model Dispute {
  id                    String   @id @default(cuid())
  // Polymorphic: exactly one of bountyId / projectId is set (CHECK in migration).
  bountyId              String?
  projectId             String?
  // Nullable so the User row can be deleted under GDPR — the dispute survives
  // with `raisedById = NULL` (and `raisedByEmailSnapshot` for ops).
  raisedById            String?
  raisedByEmailSnapshot String?
  reason                String
  status                String   @default("OPEN")
  resolution            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  bounty   Bounty?  @relation(fields: [bountyId], references: [id])
  project  Project? @relation(fields: [projectId], references: [id])
  raisedBy User?    @relation(fields: [raisedById], references: [id], onDelete: SetNull)

  @@index([bountyId])
  @@index([projectId])
  @@index([raisedById])
}

// =============================================================================
// Reviews (two-way ratings left at project completion)
// =============================================================================

model Review {
  id                String   @id @default(cuid())
  projectId         String
  raterUserId       String? // GDPR nullable
  rateeUserId       String?
  raterRole         UserRole // snapshot of who wrote it (COMPANY | FREELANCER)
  rating            Int // 1..5 (validated in Zod)
  comment           String? // sanitised HTML
  raterNameSnapshot String?
  rateeNameSnapshot String?
  createdAt         DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rater   User?   @relation("ReviewsAuthored", fields: [raterUserId], references: [id], onDelete: SetNull)
  ratee   User?   @relation("ReviewsReceived", fields: [rateeUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, raterUserId]) // one review per rater per project
  @@index([projectId])
  @@index([rateeUserId])
}

// =============================================================================
// Platform settings (new in this revision)
// =============================================================================

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  updatedAt   DateTime @updatedAt
  updatedById String?

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)
}

// =============================================================================
// Company invites (new in this revision)
// =============================================================================

model CompanyInvite {
  id             String       @id @default(cuid())
  email          String
  companyName    String?
  invitedById    String?
  status         InviteStatus @default(PENDING)
  acceptedUserId String?
  createdAt      DateTime     @default(now())
  acceptedAt     DateTime?

  invitedBy    User? @relation("InviteCreatedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedUser User? @relation("InviteAcceptedBy", fields: [acceptedUserId], references: [id], onDelete: SetNull)
  // NOTE: partial-unique index `(email) WHERE status = 'PENDING'` is appended
  // as raw SQL in the initial migration — Prisma does not yet support partial
  // unique indexes declaratively.

  @@index([email])
  @@index([invitedById])
  @@index([status])
}

// =============================================================================
// Push subscriptions (new in this revision)
// =============================================================================

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =============================================================================
// Notification preferences + notifications (revised)
//   - `Notification.channel` removed; the service fans out to email + push + in-app.
// =============================================================================

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  prefs     Json
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  title     String
  message   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType, createdAt])
}

// =============================================================================
// Credit system — freelancer submission credits ledger.
//   Idempotency is enforced via partial-unique indexes appended as raw SQL in
//   the migration (Prisma cannot model partial uniques declaratively):
//     - one SUBMISSION_SPEND per submission
//     - one WIN_BONUS per submission
//     - one SPAM_PENALTY per submission
//     - one MONTHLY_RESET per (freelancer, periodKey)
// =============================================================================

model CreditTransaction {
  id                  String          @id @default(cuid())
  freelancerProfileId String
  delta               Int // signed; +N grant, -N spend, 0 for floor-clamped no-ops
  balanceAfter        Int // post-transaction snapshot (audit aid)
  reason              CreditTxnReason
  periodKey           String // "YYYY-MM" of the period this transaction belongs to
  submissionId        String?
  proposalId          String? // idempotency key for PROPOSAL_SPEND
  bountyId            String?
  adminUserId         String?
  // Referral ledger rows: the referred freelancer whose activity triggered this row.
  // Used as the idempotency key for REFERRAL_FIRST_SUBMISSION / REFERRAL_REVERSAL.
  referredProfileId   String?
  notes               String?
  createdAt           DateTime        @default(now())

  freelancer FreelancerProfile  @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  submission Submission?        @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  proposal   ProjectProposal?   @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  bounty     Bounty?            @relation(fields: [bountyId], references: [id], onDelete: SetNull)
  adminUser  User?              @relation("CreditTxnAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)
  referred   FreelancerProfile? @relation("CreditTxnReferred", fields: [referredProfileId], references: [id], onDelete: SetNull)

  @@index([freelancerProfileId, createdAt])
  @@index([submissionId])
  @@index([proposalId])
  @@index([reason, periodKey])
  @@index([referredProfileId])
}

// =============================================================================
// GDPR account-deletion audit log.
// Has no FK to User on purpose — the row must survive the user's deletion so
// that we retain a record of who was erased, when, and by whom (self vs admin).
// =============================================================================

model AccountDeletionLog {
  id              String   @id @default(cuid())
  deletedUserId   String
  deletedEmail    String
  deletedRole     UserRole
  deletedAt       DateTime @default(now())
  // null = self-serve deletion; non-null = admin id that triggered it
  deletedByUserId String?
  reason          String?

  @@index([deletedAt])
  @@index([deletedByUserId])
}
