## Database (pooled connection for app; direct for migrations)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:pass@host/db?sslmode=require

## Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

## Seed
ADMIN_EMAIL=admin@example.com

## Monime (Phase 3+)
MONIME_ACCESS_TOKEN=
MONIME_SPACE_ID=
MONIME_WEBHOOK_SECRET=

## AI (Phase 5+)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

## Cloudinary (Phase 4+ for avatars/logos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

## Email — Resend
# If unset, send.ts logs emails to the console (dev mode)
RESEND_API_KEY=
RESEND_FROM="FOW <noreply@fow.sl>"

## Push — Web Push / VAPID (Phase 6+)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@fow.sl"

## Client-exposed (PUBLIC_ prefix required by SvelteKit)
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_ADMIN_URL=http://admin.localhost:5173
PUBLIC_VAPID_KEY=
